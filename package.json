{
  "private": true,
  "name": "tmplink-tests",
  "description": "钛盘自动化回归测试",
  "scripts": {
    "test": "npx playwright test",
    "test:auto": "cross-env TEST_AUTO=1 npx playwright test",
    "test:i18n": "npx playwright test --project=i18n",
    "test:api": "npx playwright test --project=api",
    "test:share-copy": "cross-env TEST_AUTO=1 npx playwright test --project=share-copy-desktop --project=share-copy-mobile"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "cross-env": "^7.0.3",
    "serve": "^14.2.6"
  }
}
