{
  "private": true,
  "name": "tmplink-tests",
  "description": "钛盘自动化回归测试",
  "scripts": {
    "test": "npx playwright test",
    "test:auto": "cross-env TEST_AUTO=1 npx playwright test",
    "test:i18n": "npx playwright test --project=i18n",
    "test:api": "npx playwright test --project=api",
    "test:ui": "npx playwright test --project=desktop-light --project=mobile-light --project=desktop-dark --project=mobile-dark",
    "test:desktop": "npx playwright test --project=desktop-light --project=desktop-dark",
    "test:mobile": "npx playwright test --project=mobile-light --project=mobile-dark",
    "test:dark": "npx playwright test --project=desktop-dark --project=mobile-dark",
    "baseline": "cross-env TEST_AUTO=1 npx playwright test --update-snapshots",
    "baseline:ui": "cross-env TEST_AUTO=1 npx playwright test --project=desktop-light --project=mobile-light --project=desktop-dark --project=mobile-dark --update-snapshots"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "cross-env": "^7.0.3",
    "serve": "^14.2.6"
  }
}
