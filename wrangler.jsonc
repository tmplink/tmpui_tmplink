{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tmpui-tmplink",
  "compatibility_date": "2026-06-11",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "exclude": [
      "node_modules/**",
      ".git/**",
      "tests/**",
      "ai/**",
      "docs/**",
      "**/*.md",
      ".gitignore",
      "package-lock.json"
    ]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}